# Refinement tree state — the structured form of the plan.
# Persisted alongside conversation.md, decisions.md, threat-model.md, manifest.yaml.
# YAML chosen over JSON for diffability in PR review.

plan:
  epic_id: AR-EPIC-42                    # Linear epic ID
  epic_title: "Implement bulk asset export"
  started_at: 2026-06-08T10:00:00Z
  driver: nicky@ar
  status: in_refinement                  # in_refinement | paused | complete | abandoned

# Ring of relevant context pulled from gbrain at session start
context:
  related_past_plans:
    - plans/AR-EPIC-33-asset-listing/    # similar export-shaped work
  relevant_adrs:
    - ADR-005  # repository pattern (affects how export reads data)
    - ADR-007  # audit log (export is an audited event)
    - ADR-009  # multi-tenancy (export must respect schema-per-tenant)
    - ADR-018  # data handling (bulk export is a sensitive operation)

# The tree itself — flat list of nodes with parent references.
# Easier to manipulate and diff than nested YAML.
nodes:

  # Root
  - id: root
    parent: null
    type: epic
    title: "Implement bulk asset export"
    linear_id: AR-EPIC-42
    status: in_refinement
    flag: null                            # root expanded by Analyst at kickoff
    children: [scope, threat-model, decision-1, story-1, story-2, story-3, story-4]

  # Scope outcome from Analyst interview
  - id: scope
    parent: root
    type: scope_node
    title: "Scope assessment"
    status: complete
    output: plans/AR-EPIC-42/scope.md
    decision_required: false

  # Threat model (mandatory at epic kickoff)
  - id: threat-model
    parent: root
    type: threat_model
    title: "Threat model for bulk asset export"
    status: complete
    output: plans/AR-EPIC-42/threat-model.md
    transcript_captured: true
    reviewed_by: nicky@ar
    reviewed_at: 2026-06-08T11:14:00Z

  # An architectural decision surfaced during refinement
  - id: decision-1
    parent: root
    type: decision
    title: "Streaming export vs paginated batch"
    status: complete
    flag: needs-decision
    promoted_to_adr: ADR-021
    decision_required: true
    decided_at: 2026-06-08T12:30:00Z

  # Stories — leaves that have reached DoR-ready
  - id: story-1
    parent: root
    type: story
    title: "Define export request API endpoint"
    flag: DoR-ready-check
    status: dor_ready
    facets: [request-path]
    linked_adrs: [ADR-005, ADR-009, ADR-021]
    points: 2
    ac:
      - text: "Given an authenticated user with export permission, when POST /api/v1/exports is called with a valid request, then a 202 Accepted with an export ID is returned"
        provenance: event:ExportRequested
      - text: "Given an unauthenticated request, when POST /api/v1/exports is called, then a 401 is returned"
        provenance: ADR-009
      - text: "Given a request from a different tenant context, when an export ID is queried, then a 404 is returned (not 403 — no information leak)"
        provenance: threat-3
    dependencies: []                      # implementable in isolation
    nfr:
      latency_p99_ms: baseline            # inherits method.config.yaml (300ms)
      over_limit: "n/a — creation endpoint; request volume bounded by story-3"
      assert: verify-in-review
    telemetry:
      - "metric: export_requests_total{tenant,result}"
      - "log: export.requested with export_id, actor"
    edges:
      - case: unauthenticated
        handling: "AC-2 — 401"
      - case: wrong-tenant
        handling: "AC-3 — 404, no info leak"
      - case: malformed-request
        handling: "dismissed — schema validation handled by framework middleware (ADR-005)"
    stop_conditions: [standard]
    test_file: plans/AR-EPIC-42/tests/export_api_test.go
    linear_id: AR-142
    promoted_to_linear_at: 2026-06-08T14:22:00Z
    decision_required: false

  - id: story-2
    parent: root
    type: story
    title: "Audit log emission for export operations"
    flag: DoR-ready-check
    status: dor_ready
    linked_adrs: [ADR-007]
    points: 1
    ac:
      - "Given an export is initiated, when it completes successfully, then an audit_events row of type 'export.completed' is written in the same transaction as the export status update"
      - "Given an export fails, when the failure is recorded, then an audit_events row of type 'export.failed' is written with the failure reason in metadata"
    stop_conditions: [standard]
    test_file: plans/AR-EPIC-42/tests/export_audit_test.go
    evidenced_controls:
      soc2: [CC7.2]
      iso27001: [A.8.15]
    linear_id: AR-143
    decision_required: false

  - id: story-3
    parent: root
    type: story
    title: "Bulk export rate limiting per tenant"
    flag: DoR-ready-check
    status: open                          # not yet at DoR-ready
    facets: [shared-resource, request-path]
    linked_adrs: [ADR-009, ADR-021]
    points: 3
    ac:
      - text: "Given a tenant has initiated 5 exports in the last hour, when a 6th export is requested, then a 429 Too Many Requests is returned"
        provenance: event:ExportThrottled
      - text: "Given the limit window has passed, when a new export is requested, then it proceeds normally"
        provenance: event:ExportThrottled
    dependencies:
      - on: story-1
        for: "POST /api/v1/exports accepts a request and returns an export ID"
    nfr:
      rate_limit: "5 per tenant per rolling hour"   # deviation from baseline — set by capacity review
      over_limit: "429 Too Many Requests, with Retry-After"
      assert: testable-now                          # the 6th-request behaviour is a behavioural test
    telemetry:
      - "metric: export_rate_limited_total{tenant}"
    edges:
      - case: limit-exceeded
        handling: "AC-1 — 429"
      - case: window-reset
        handling: "AC-2 — proceeds"
      - case: concurrent-burst
        handling: "dismissed — limiter is atomic per tenant (ADR-021); race covered by the integration test"
    stop_conditions: [standard]
    test_file: null                       # Test Author hasn't run yet
    linear_id: null                       # not yet promoted to tracker
    decision_required: false

  # A UI story — states + accessibility bar as signed criteria; no Method-owned visual test
  - id: story-4
    parent: root
    type: story
    title: "Export status panel"
    flag: needs-test-spec
    status: open
    facets: [ui]
    linked_adrs: ["no-architectural-impact"]
    points: 2
    ac:
      - text: "Given an export is in progress, when the user opens the panel, then a progress state with percentage is shown"
        provenance: read-model:ExportStatus
    dependencies:
      - on: story-1
        for: "an export ID and its status are queryable"
    ui_states:
      - "loading — skeleton while status loads"
      - "empty — no exports yet, with a primary action"
      - "error — status fetch failed, with a retry affordance"
      - "success — completed, with a download link"
      - "disabled — download disabled until the export completes"
    accessibility: "WCAG 2.2 AA — keyboard operable, status announced via aria-live"   # signed checklist
    edges:
      - case: status-fetch-failed
        handling: "error state above"
    stop_conditions: [standard]
    # interaction test only; the visual/a11y 'done' is the signed checklist above
    test_file: plans/AR-EPIC-42/tests/export_panel_interaction_test.ts
    decision_required: false

# Open questions blocking progress
open_questions:
  - id: q1
    question: "Should bulk export be available to read-only users or only to users with explicit export permission?"
    blocking_node: story-1
    raised_at: 2026-06-08T11:30:00Z
    raised_by: analyst-agent
    resolved: false

# Promotion log — every canonical artifact produced this session
promotions:
  - artifact: ADR-021
    rule: adr_promotion
    promoted_at: 2026-06-08T12:30:00Z
    confirmed_by: nicky@ar
  - artifact: Linear AR-142
    rule: linear_story_promotion
    promoted_at: 2026-06-08T14:22:00Z
    confirmed_by: nicky@ar
  - artifact: Linear AR-143
    rule: linear_story_promotion
    promoted_at: 2026-06-08T14:25:00Z
    confirmed_by: nicky@ar
